# Local .terraform directory (contains binaries and plugins)
.terraform/

# .tfstate files (contain cloud state and potentially sensitive data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Local variables (if they contain secrets or project-specific IDs)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
_override.tf
_override.tf.json

# Terraform CLI configuration
.terraformrc
terraform.rc